# .worktreeinclude
# Files matching these patterns will be copied from the main checkout
# into agent worktrees. Uses gitignore syntax.
# Without this, workers in isolated worktrees miss environment files
# and local configs, causing silent failures.

# Environment files
.env
.env.local
.env.development
.env.test

# Local configuration
*.local.json
*.local.yaml
*.local.toml

# Claude Code local settings
.claude/settings.local.json

# Database / service configs (uncomment as needed)
# docker-compose.override.yml
# .database-url
# .service-account.json
